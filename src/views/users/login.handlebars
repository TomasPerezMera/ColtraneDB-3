<div class="auth-container">
    <div class="auth-card gradient-border">
        <h1 class="auth-title">Iniciar Sesión</h1>
        <hr>
        <form class="auth-form" method="POST" action="/api/sessions/login">
            <div class="form-group">
                <label for="email">Email</label>
                <input
                    type="email"
                    id="email"
                    name="email"
                    class="form-input"
                    placeholder="tu@email.com"
                    required
                >
            </div>
            <div class="form-group">
                <label for="password">Contraseña</label>
                <input
                    type="password"
                    id="password"
                    name="password"
                    class="form-input"
                    minlength="6"
                    required
                >
            </div>
            <hr>
            <div class="form-actions">
                <button type="submit" class="btn btn--primary">
                    Ingresar
                </button>
                <a href="/register" class="btn">
                    Crear cuenta
                </a>
                <a href="/forgot-password" class="btn">¿Olvidaste tu contraseña?</a>
            </div>
            <hr>
        </form>
        <div class="auth-alternative github-login">
            <p>O ingresá con:</p>
            <a href="/api/sessions/github" class="btn--github">
                <button class="btn btn--primary">Login con Github</button>
            </a>
        </div>
    </div>
</div>